{
  "name": "n8n-nodes-mentionfox",
  "version": "0.1.1",
  "description": "n8n community node for MentionFox + FoxAPIs - subject vetting, mention scanning, lead enrichment, GEOFixer, pipeline watch, dossiers, and journalism discovery via the MentionFox MCP server.",
  "keywords": [
    "n8n-community-node-package",
    "mentionfox",
    "foxapis",
    "osint",
    "lead-generation",
    "social-listening",
    "due-diligence",
    "dossier",
    "geofixer",
    "vc",
    "investor",
    "founder-vetting",
    "journalism"
  ],
  "license": "MIT",
  "homepage": "https://mentionfox.com",
  "author": {
    "name": "Saul Fleischman",
    "email": "saul@mentionfox.com",
    "url": "https://mentionfox.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OsakaSaul/n8n-nodes-mentionfox.git"
  },
  "engines": {
    "node": ">=18.10",
    "pnpm": ">=8.6"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json",
    "test": "jest"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MentionFoxApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MentionFox/MentionFox.node.js",
      "dist/nodes/MentionFox/MentionFoxTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^18.16.16",
    "@typescript-eslint/parser": "^6.4.1",
    "eslint": "^8.45.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.1.6",
    "n8n-workflow": "^1.55.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
